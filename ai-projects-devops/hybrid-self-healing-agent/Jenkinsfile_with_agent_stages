pipeline {
    agent none 

    options {
        // 🔥 FIX: Tells Jenkins NOT to run the hidden background checkout stepppppppppp
        skipDefaultCheckout() 
    }

    stages {
        // --- STAGE 1: THE REPO CHECKOUT & MAVEN BUILD ---
        stage('Build & Compile Application') {
            agent {
                node {
                    label 'helm'
                }
            }
            steps {
                script {
                    // This explicit HTTPS checkout will now run cleanly on its own!
                    git branch: 'main',
                        url: 'https://github.com/alian2000/MLOPS.git'

                    def status = sh(script: '''
                        cd ai-projects-devops/hybrid-self-healing-agent
                        echo "🚀 Running Maven Build on helm agent pod..."
                        mvn clean install -U > build.log 2>&1
                    ''', returnStatus: true)

                    def log = readFile 'ai-projects-devops/hybrid-self-healing-agent/build.log'
                    echo "===== BUILD LOG START ====="
                    echo log
                    echo "===== BUILD LOG END ====="

                    if (status != 0) {
                        echo "❌ Maven Build Failed"
                        writeFile file: 'ai-projects-devops/hybrid-self-healing-agent/build_failed', text: 'failed'
                    }
                }
            }
        }

        // --- STAGE 2: THE SELF-HEALING FIX ---
        stage('AI Self-Healing Fix') {
            when {
                expression {
                    return fileExists('ai-projects-devops/hybrid-self-healing-agent/build_failed')
                }
            }
            agent {
                node {
                    label 'helm'
                }
            }
            steps {
                script {
                    echo "🤖 Running Hybrid AI Fix on helm agent pod..."
                    
                    sshagent(credentials: ['github-ssh-key']) {
                        sh '''
                        cd ai-projects-devops/hybrid-self-healing-agent
                        
                        if command -v python3 &> /dev/null
                        then
                            python3 ai_agent.py
                        else
                            python ai_agent.py
                        fi
                        
                        git config user.email "jenkins-helm@ai.com"
                        git config user.name "Helm AI Agent Bot"
                        
                        export GIT_SSH_COMMAND="ssh -o StrictHostKeyChecking=no"
                        
                        git add .
                        
                        if git diff --cached --quiet; then
                          echo "No changes needed."
                        else
                          git commit -m "[ai] auto-fix code via helm worker node"
                          
                          git remote set-url origin git@github.com:alian2000/MLOPS.git
                          
                          git push origin :ai-test-fixes || true
                          git push origin main:ai-test-fixes
                        fi
                        '''
                    }
                }
            }
        }
    }
}
