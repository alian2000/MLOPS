pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    stages {
        stage('Clone Code') {
            steps {
                // 1. Updated to use your 'github-ssh-key' and SSH URL style
                git branch: 'main',
                    credentialsId: 'github-ssh-key',
                    url: 'git@github.com:alian2000/MLOPS.git'
            }
        }

        stage('Skip AI Loop') {
            steps {
                script {
                    def msg = sh(script: "git log -1 --pretty=%B", returnStdout: true).trim()
                    echo "Last commit message: ${msg}"

                    if (msg.contains("[ai]")) {
                        echo "AI commit detected → stopping loop"
                        currentBuild.result = 'SUCCESS'
                        return
                    }
                }
            }
        }

        stage('Build with Maven') {
            steps {
                script {
                    def status = sh(script: '''
                        cd ai-projects-devops/hybrid-self-healing-agent
                        mvn clean install -U > build.log 2>&1
                    ''', returnStatus: true)

                    def log = readFile 'ai-projects-devops/hybrid-self-healing-agent/build.log'
                    echo "===== BUILD LOG START ====="
                    echo log
                    echo "===== BUILD LOG END ====="

                    if (status != 0) {
                        echo "❌ Build Failed"
                        writeFile file: 'ai-projects-devops/hybrid-self-healing-agent/build_failed', text: 'failed'
                    } else {
                        echo "✅ Build Passed"
                    }
                }
            }
        }

        stage('AI Fix') {
            when {
                expression {
                    return fileExists('ai-projects-devops/hybrid-self-healing-agent/build_failed')
                }
            }
            steps {
                script {
                    echo "🤖 Running Hybrid AI Fix..."

                    // 2. Swapped usernamePassword for sshUserPrivateKey wrapper
                    sshagent(credentials: ['github-ssh-key']) {
                        sh '''
                        cd ai-projects-devops/hybrid-self-healing-agent

                        if command -v python3 &> /dev/null
                        then
                            python3 ai_agent.py
                        else
                            python ai_agent.py
                        fi

                        git config user.email "jenkins@ai.com"
                        git config user.name "Jenkins AI Bot"

                        git add .

                        if git diff --cached --quiet; then
                          echo "No changes"
                        else
                          git commit -m "[ai] auto-fix code + dependency issue"
                          
                          # 3. Use SSH endpoint URL for the push operation instead of HTTPS
                          git remote set-url origin git@github.com:alian2000/MLOPS.git
                          git push origin main
                        fi
                        '''
                    }
                }
            }
        }

        stage('Rebuild After Fix') {
            when {
                expression {
                    return fileExists('ai-projects-devops/hybrid-self-healing-agent/build_failed')
                }
            }
            steps {
                script {
                    def status = sh(script: '''
                        cd ai-projects-devops/hybrid-self-healing-agent
                        mvn clean install -U
                    ''', returnStatus: true)

                    if (status != 0) {
                        error("❌ Build still failing after AI fix")
                    } else {
                        echo "✅ Build Fixed Successfully"
                    }
                }
            }
        }
    }
}
