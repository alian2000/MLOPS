pipeline {
    // 1. Point the entire pipeline execution to your 'helm1' node
    agent {
        node {
            label 'helm'
        }
    }

    tools {
        maven 'Maven3'
    }

    stages {
        stage('Clone Code') {
            steps {
                // 2. Pointing to your credentialsId 'github-ssh-key' and git URL style
                git branch: 'main',
                    credentialsId: 'github-ssh-key',
                    url: 'git@github.com:alian2000/MLOPS.git'
            }
        }

        stage('Build with Maven') {
            steps {
                script {
                    def status = sh(script: '''
                        cd ai-projects/hybrid-self-healing-agent
                        echo "🚀 Running Maven Build on helm1 node..."
                        mvn clean install -U > build.log 2>&1
                    ''', returnStatus: true)

                    def log = readFile 'ai-projects/hybrid-self-healing-agent/build.log'
                    echo "===== BUILD LOG START ====="
                    echo log
                    echo "===== BUILD LOG END ====="

                    if (status != 0) {
                        echo "❌ Build Failed"
                        writeFile file: 'ai-projects/hybrid-self-healing-agent/build_failed', text: 'failed'
                    } else {
                        echo "✅ Build Passed"
                    }
                }
            }
        }
    }
}
