pipeline {

    agent any

    tools {
        maven 'Maven3'
    }

    environment {
        PROJECT_PATH = "ai-projects/multi-agent-openai-cicd"
    }

    stages {

        stage('Clone Check') {
            steps {
                echo "Repository cloned successfully"
            }
        }



       stage('Build') {

    steps {

        script {

            def status = sh(
                script: '''
                cd ai-projects/multi-agent-openai-cicd

                mkdir -p reports

                mvn clean install -U > build.log 2>&1
                ''',
                returnStatus: true
            )

            echo "Build Status: ${status}"

            if (status != 0) {

                echo "❌ Build Failed"

                writeFile(
                    file: 'ai-projects/multi-agent-openai-cicd/build_failed',
                    text: 'failed'
                )

            } else {

                echo "✅ Build Success"

            }

        }

    }

}



        stage('Project Agent') {
            steps {

                sh '''
                cd ${PROJECT_PATH}

                export PYTHONPATH=$(pwd)

                python3 agents/project_agent.py
                '''

            }
        }

        stage('Security Agent') {
            steps {

                sh '''
                cd ${PROJECT_PATH}

                export PYTHONPATH=$(pwd)

                python3 agents/security_agent.py
                '''

            }
        }

        stage('Decision Agent') {
            steps {

                sh '''
                cd ${PROJECT_PATH}

                export PYTHONPATH=$(pwd)

                python3 agents/decision_agent.py
                '''

            }
        }

        stage('Fix Agent') {

            when {
                expression {
                    return fileExists("${PROJECT_PATH}/build_failed")
                }
            }

            steps {

                sh '''
                cd ${PROJECT_PATH}

                export PYTHONPATH=$(pwd)

                python3 agents/fix_agent.py
                '''

            }

        }
	stage('Push AI Fixes') {

    steps {

        withCredentials([
            usernamePassword(
                credentialsId: 'github-creds',
                usernameVariable: 'GIT_USER',
                passwordVariable: 'GIT_PASS'
            )
        ]) {

            sh '''
            cd ${PROJECT_PATH}

            echo "📂 Current Path"
            pwd

            echo "📌 Git Status"
            git status

            echo "🌿 Current Branch"
            git branch

            echo "🔄 Checkout main"
            git checkout main

            echo "➕ Adding changes"
            git add .

            echo "📝 Commit changes"
            git commit -m "🤖 AI Auto Fix" || true

            echo "🔗 Setting remote"
            git remote set-url origin https://${GIT_USER}:${GIT_PASS}@github.com/Rohitcs09/MLOPS.git

            echo "⬇️ Pull latest"
            git pull origin main --rebase || true

            echo "⬆️ Push changes"
            git push origin main --force

            echo "✅ GitHub Updated"
            '''

        }

    }

}

        stage('Rebuild') {

            when {
                expression {
                    return fileExists("${PROJECT_PATH}/build_failed")
                }
            }

            steps {

                sh '''
                cd ${PROJECT_PATH}

                mvn clean install -U
                '''

            }

        }

    }

    post {

        always {

            archiveArtifacts artifacts: '**/reports/*.json', fingerprint: true

        }

    }

}
