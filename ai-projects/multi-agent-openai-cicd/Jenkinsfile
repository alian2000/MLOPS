pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    environment {
        OPENAI_API_KEY = credentials('OPENAI_API_KEY')
    }

    stages {




           stage('Build') {
            steps {
                sh 'mvn clean install -U > build.log || true'
            }
        }

       


        stage('Project Agent') {
            steps {
                sh 'python3 ai-projects/multi-agent-openai-cicd/agents/project_agent.py'
            }
        }

        stage('Security Agent') {
            steps {
                sh 'python3 ai-projects/multi-agent-openai-cicd/agents/security_agent.py'
            }
        }

 

        stage('Combine Report') {
    steps {
        dir("ai-projects/multi-agent-openai-cicd") {
            sh '''
            echo "📁 Current dir:"
            pwd

            mkdir -p reports

            echo "📊 Combining reports..."

            cat reports/project.json reports/security.json > reports/combined.txt

            echo "✅ Combined report created"
            '''
        }
    }
}


        stage('Decision Agent') {
            steps {
                sh 'python3 ai-projects/multi-agent-openai-cicd/agents/decision_agent.py'
            }
        }

        stage('Fix Agent') {
            when {
                expression { fileExists('build_failed') }
            }
            steps {
                sh 'python3 ai-projects/multi-agent-openai-cicd/agents/fix_agent.py'
            }
        }

        stage('Push AI Fixes to GitHub') {
    steps {
        withCredentials([usernamePassword(
            credentialsId: '77574aa6-ebb8-4641-9540-da90dbcb1576',
            usernameVariable: 'GIT_USER',
            passwordVariable: 'GIT_PASS'
        )]) {

            sh '''
            cd ai-projects/multi-agent-openai-cicd

            echo "📦 Git Status"
            git status

            git config user.email "jenkins@ai.com"
            git config user.name "AI Fix Agent"

            git add -A

            if git diff --cached --quiet; then
                echo "⚠️ No changes to commit"
                exit 0
            fi

            git commit -m "[AI] Auto Fix Applied"

            git remote set-url origin https://$GIT_USER:$GIT_PASS@github.com/Rohitcs09/MLOPS.git

            echo "🚀 Pushing to GitHub..."
            git push origin main --force

            echo "✅ GitHub Updated"
            '''
        }
    }
}
    
    stage('Rebuild After Fix') {
    steps {
        sh '''
        cd ai-projects/multi-agent-openai-cicd

        echo "🔁 Rebuilding project after AI fix..."

        mvn clean install -U > build.log 2>&1

        echo "📄 Build completed"
        '''
    }
}


    }
}
