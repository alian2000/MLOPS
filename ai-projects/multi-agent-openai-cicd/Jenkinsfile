pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    environment {
        OPENAI_API_KEY = credentials('OPENAI_API_KEY')
    }

    stages {

            stage('Clone Code') {
            steps {
                git branch: 'main',
                    credentialsId: '77574aa6-ebb8-4641-9540-da90dbcb1576',
                    url: 'https://github.com/Rohitcs09/MLOPS.git'
            }
        }


        
           stage('Skip AI Loop') {
            steps {
                script {
                    def msg = sh(script: "git log -1 --pretty=%B", returnStdout: true).trim()
                    echo "Last commit message: ${msg}"

                    if (msg.contains("[ai]")) {
                        echo "AI commit detected → stopping loop"
                        currentBuild.result = 'SUCCESS'
                        return
                    }
                }
            }
        }
        




          stage('Build with Maven') {
            steps {
                script {
                    def status = sh(script: '''
                        cd ai-projects/multi-agent-openai-cicd
                        mvn clean install -U > build.log 2>&1
                    ''', returnStatus: true)

                    def log = readFile 'ai-projects/multi-agent-openai-cicd/build.log'
                    echo "===== BUILD LOG START ====="
                    echo log
                    echo "===== BUILD LOG END ====="

                    if (status != 0) {
                        echo "❌ Build Failed"
                        writeFile file: 'ai-projects/multi-agent-openai-cicd/build_failed', text: 'failed'
                    } else {
                        echo "✅ Build Passed"
                    }
                }
            }
        }

       


        stage('Project Agent') {
            steps {
                sh 'python3 ai-projects/multi-agent-openai-cicd/agents/project_agent.py'
            }
        }

        stage('Security Agent') {
            steps {
                sh 'python3 ai-projects/multi-agent-openai-cicd/agents/security_agent.py'
            }
        }


        stage('Combine Report') {
    steps {
        dir("ai-projects/multi-agent-openai-cicd") {
            sh '''
            echo "📁 Current dir:"
            pwd

            mkdir -p reports

            echo "📊 Combining reports..."

            cat reports/project.json reports/security.json > reports/combined.txt

            echo "✅ Combined report created"
            '''
        }
    }
}


        stage('Decision Agent') {
            steps {
                sh 'python3 ai-projects/multi-agent-openai-cicd/agents/decision_agent.py'
            }
        }

        stage('Fix Agent') {
            when {
                expression { fileExists('build_failed') }
            }
            steps {
                sh 'python3 ai-projects/multi-agent-openai-cicd/agents/fix_agent.py'
            }
        }



         // ------------------------------- // 🤖 AI FIX STAGE // ------------------------------- stage('AI Fix') { when { expression { return fileExists('ai-projects/openai_self-healing-agent/build_failed') } } steps { script { echo "🤖 Running AI Fix..." withCredentials([ usernamePassword( credentialsId: '77574aa6-ebb8-4641-9540-da90dbcb1576', usernameVariable: 'GIT_USER', passwordVariable: 'GIT_PASS' ), string( credentialsId: 'OPENAI_API_KEY', variable: 'OPENAI_API_KEY' ) ]) { sh ''' cd ai-projects/openai_self-healing-agent echo "📂 Current Path:" pwd echo "📦 Installing dependencies..." python3 -m pip install --break-system-packages openai python-dotenv export OPENAI_API_KEY=$OPENAI_API_KEY echo "🤖 Running AI Agent..." python3 ai-agent.py echo "📄 Showing Updated Files" cat ai-devops-maven/pom.xml || true cat ai-devops-maven/src/main/java/App.java || true git config user.email "jenkins@ai.com" git config user.name "Jenkins AI Bot" git checkout main || true git add . if git diff --cached --quiet; then echo "⚠️ No changes detected" else echo "📝 Commiting AI fixes..." git commit -m "[ai] auto-fix dependency + syntax issue" git remote set-url origin https://$GIT_USER:$GIT_PASS@github.com/Rohitcs09/AI-DevOps.git echo "⬆️ Pushing AI fixes..." git push origin HEAD:main --force echo "✅ GitHub updated" fi ''' } } } } // ------------------------------- // 🔁 REBUILD AFTER FIX // ------------------------------- stage('Rebuild After Fix') { when { expression { return fileExists('ai-projects/openai_self-healing-agent/build_failed') } } steps { script { def status = sh(script: ''' cd ai-projects/openai_self-healing-agent/ai-devops-maven echo "🔁 Rebuilding after AI fix..." mvn clean install -U ''', returnStatus: true) if (status != 0) { error("❌ Build still failing after AI fix") } else { echo "✅ BUILD FIXED SUCCESSFULLY" } } } }




















    }
}
