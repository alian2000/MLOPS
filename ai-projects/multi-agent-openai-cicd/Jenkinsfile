pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    environment {
        OPENAI_API_KEY = credentials('OPENAI_API_KEY')
    }

    stages {



      stage('Build') {
    steps {
        dir("ai-projects/multi-agent-openai-cicd") {

            script {
                echo "🏗 Running Maven Build..."

                def status = sh(
                    script: 'mvn clean install -U > build.log 2>&1',
                    returnStatus: true
                )

                echo "📊 Maven Exit Code: ${status}"

                sh 'tail -n 50 build.log || true'

                if (status != 0) {
                    error("❌ Maven Build FAILED (check build.log)")
                }

                echo "✅ Build SUCCESS"
            }
        }
    }
}



        stage('Project Agent') {
            steps {
                sh 'python3 ai-projects/multi-agent-openai-cicd/agents/project_agent.py'
            }
        }

        stage('Security Agent') {
            steps {
                sh 'python3 ai-projects/multi-agent-openai-cicd/agents/security_agent.py'
            }
        }

 

        stage('Combine Report') {
    steps {
        dir("ai-projects/multi-agent-openai-cicd") {
            sh '''
            echo "📁 Current dir:"
            pwd

            mkdir -p reports

            echo "📊 Combining reports..."

            cat reports/project.json reports/security.json > reports/combined.txt

            echo "✅ Combined report created"
            '''
        }
    }
}


        stage('Decision Agent') {
            steps {
                sh 'python3 ai-projects/multi-agent-openai-cicd/agents/decision_agent.py'
            }
        }

        stage('Fix Agent') {
            when {
                expression { fileExists('build_failed') }
            }
            steps {
                sh 'python3 ai-projects/multi-agent-openai-cicd/agents/fix_agent.py'
            }
        }
    }
}
