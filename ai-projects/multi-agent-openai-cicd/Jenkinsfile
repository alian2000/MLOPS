pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    environment {
        OPENAI_API_KEY = credentials('OPENAI_API_KEY')
    }

    stages {

        // -------------------------------
        // 📥 CLONE
        // -------------------------------
        stage('Clone Code') {
            steps {
                git branch: 'main',
                    credentialsId: '77574aa6-ebb8-4641-9540-da90dbcb1576',
                    url: 'https://github.com/Rohitcs09/MLOPS.git'
            }
        }

        // -------------------------------
        // 🏗 BUILD
        // -------------------------------
        stage('Build') {
            steps {
                script {
                    dir("ai-projects/multi-agent-openai-cicd") {

                        def status = sh(script: 'mvn clean install -U > build.log 2>&1', returnStatus: true)

                        if (status != 0) {
                            echo "❌ BUILD FAILED"
                            currentBuild.result = 'FAILURE'
                        } else {
                            echo "✅ BUILD SUCCESS"
                        }
                    }
                }
            }
        }

        // -------------------------------
        // 🤖 PROJECT AGENT
        // -------------------------------
        stage('Project Agent') {
            steps {
                dir("ai-projects/multi-agent-openai-cicd") {
                    sh '''
                    echo "🤖 Project Agent running..."
                    python3 agents/project_agent.py
                    '''
                }
            }
        }

        // -------------------------------
        // 🔐 SECURITY AGENT
        // -------------------------------
        stage('Security Agent') {
            steps {
                dir("ai-projects/multi-agent-openai-cicd") {
                    sh '''
                    echo "🔐 Security Agent running..."
                    python3 agents/security_agent.py
                    '''
                }
            }
        }

        // -------------------------------
        // 📊 COMBINE REPORT
        // -------------------------------
        stage('Combine Report') {
            steps {
                dir("ai-projects/multi-agent-openai-cicd") {
                    sh '''
                    mkdir -p reports
                    cat reports/project.json reports/security.json > reports/combined.txt || true
                    echo "✅ Reports combined"
                    '''
                }
            }
        }

        // -------------------------------
        // 🧠 DECISION AGENT
        // -------------------------------
        stage('Decision Agent') {
            steps {
                dir("ai-projects/multi-agent-openai-cicd") {
                    sh '''
                    python3 agents/decision_agent.py
                    '''
                }
            }
        }

        // -------------------------------
        // 🤖 AI FIX (ONLY ON FAILURE)
        // -------------------------------
        stage('AI Fix') {
            when {
                expression {
                    return currentBuild.result == 'FAILURE'
                }
            }

            steps {
                script {

                    withCredentials([
                        usernamePassword(
                            credentialsId: '77574aa6-ebb8-4641-9540-da90dbcb1576',
                            usernameVariable: 'GIT_USER',
                            passwordVariable: 'GIT_PASS'
                        ),
                        string(
                            credentialsId: 'OPENAI_API_KEY',
                            variable: 'OPENAI_API_KEY'
                        )
                    ]) {

                        dir("ai-projects/multi-agent-openai-cicd") {

                            sh '''
                            echo "🤖 Running AI Fix Agent..."

			    pwd
			    ls -l agents/

                            python3 agents/fix_agent.py

                            git config user.email "jenkins@ai.com"
                            git config user.name "AI Bot"

                            git add -A

                            git commit -m "[AI] auto fix applied" || true

                            git remote set-url origin https://$GIT_USER:$GIT_PASS@github.com/Rohitcs09/MLOPS.git

                            git push origin main --force || true
                            '''
                        }
                    }
                }
            }
        }

        // -------------------------------
        // 🔁 REBUILD AFTER FIX
        // -------------------------------
    
         stage('Rebuild After Fix') {

    steps {
        script {

            // run only if build_failed exists OR previous stage failed
            if (fileExists('ai-projects/multi-agent-openai-cicd/build_failed')) {

                dir("ai-projects/multi-agent-openai-cicd") {

                    def status = sh(script: 'mvn clean install -U > build_after_fix.log 2>&1', returnStatus: true)

                    if (status != 0) {

                        error("❌ Build still failing after AI fix")

                    } else {

                        echo "✅ REBUILD SUCCESS AFTER AI FIX"

                        // FIX FILE CLEANUP
                        sh 'rm -f build_failed || true'
                    }
                }

            } else {
                echo "⚠️ No rebuild needed"
            }
        }
    }
}



    }

}
