pipeline {

    agent any

    tools {
        maven 'Maven'
    }

    environment {
        PROJECT_PATH = "ai-projects/multi-agent-openai-cicd"
    }

    stages {

        // ------------------------------------------------
        // 📥 CLONE
        // ------------------------------------------------
        stage('Clone Repository') {

            steps {

                git branch: 'main',
                url: 'https://github.com/Rohitcs09/MLOPS.git'

                echo "✅ Repository cloned successfully"
            }
        }

        // ------------------------------------------------
        // 🏗 BUILD
        // ------------------------------------------------
        stage('Build') {

            steps {

                script {

                    def status = sh(script: '''
                    cd ${PROJECT_PATH}

                    mkdir -p reports

                    echo "🏗 Running Maven Build..."

                    mvn clean install -U > build.log 2>&1
                    ''', returnStatus: true)

                    if (status != 0) {

                        sh '''
                        touch ${PROJECT_PATH}/build_failed
                        '''

                        echo "❌ Build Failed"

                    } else {

                        sh '''
                        rm -f ${PROJECT_PATH}/build_failed
                        '''

                        echo "✅ Build Success"
                    }
                }
            }
        }

        // ------------------------------------------------
        // 🤖 PROJECT AGENT
        // ------------------------------------------------
        stage('Project Agent') {

            when {
                expression {
                    return fileExists("${PROJECT_PATH}/build_failed")
                }
            }

            steps {

                sh '''
                cd ${PROJECT_PATH}

                export PYTHONPATH=$(pwd)

                echo "🤖 Running Project Agent..."

                python3 agents/project_agent.py
                '''
            }
        }

        // ------------------------------------------------
        // 🔐 SECURITY AGENT
        // ------------------------------------------------
        stage('Security Agent') {

            when {
                expression {
                    return fileExists("${PROJECT_PATH}/build_failed")
                }
            }

            steps {

                sh '''
                cd ${PROJECT_PATH}

                export PYTHONPATH=$(pwd)

                echo "🔐 Running Security Agent..."

                python3 agents/security_agent.py
                '''
            }
        }

        // ------------------------------------------------
        // 🧠 DECISION AGENT
        // ------------------------------------------------
        stage('Decision Agent') {

            when {
                expression {
                    return fileExists("${PROJECT_PATH}/build_failed")
                }
            }

            steps {

                withCredentials([
                    string(
                        credentialsId: 'OPENAI_API_KEY',
                        variable: 'OPENAI_API_KEY'
                    )
                ]) {

                    sh '''
                    cd ${PROJECT_PATH}

                    export PYTHONPATH=$(pwd)

                    echo "🧠 Running Decision Agent..."

                    python3 agents/decision_agent.py
                    '''
                }
            }
        }

        // ------------------------------------------------
        // 🔧 FIX AGENT
        // ------------------------------------------------



         stage('Fix Agent') {

    when {
        expression {
            return fileExists("${PROJECT_PATH}/build_failed")
        }
    }

    steps {

        withCredentials([

            string(
                credentialsId: 'OPENAI_API_KEY',
                variable: 'OPENAI_API_KEY'
            ),

            usernamePassword(
                credentialsId: 'github-creds',
                usernameVariable: 'GIT_USER',
                passwordVariable: 'GIT_PASS'
            )

        ]) {

            sh '''
            cd ${PROJECT_PATH}

            echo "📄 Showing Fix Agent File"

            cat agents/fix_agent.py

            export PYTHONPATH=$(pwd)

            export OPENAI_API_KEY=$OPENAI_API_KEY

            echo "🤖 Running Fix Agent..."

            python3 agents/fix_agent.py
            '''
        }
    }
}


        // ------------------------------------------------
        // 🔁 REBUILD
        // ------------------------------------------------
        stage('Rebuild After Fix') {

            when {
                expression {
                    return fileExists("${PROJECT_PATH}/build_failed")
                }
            }

            steps {

                script {

                    def rebuildStatus = sh(script: '''
                    cd ${PROJECT_PATH}

                    echo "🔁 Rebuilding after AI fix..."

                    mvn clean install -U
                    ''', returnStatus: true)

                    if (rebuildStatus != 0) {

                        error("❌ Build still failing")

                    } else {

                        sh '''
                        rm -f ${PROJECT_PATH}/build_failed
                        '''

                        echo "✅ BUILD FIXED SUCCESSFULLY"
                    }
                }
            }
        }
    }

    // ------------------------------------------------
    // 📦 REPORTS
    // ------------------------------------------------
    post {

        always {

            archiveArtifacts artifacts: 'ai-projects/multi-agent-openai-cicd/reports/*', fingerprint: true

        }
    }
}
