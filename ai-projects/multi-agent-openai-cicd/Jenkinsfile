pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    environment {
        OPENAI_API_KEY = credentials('OPENAI_API_KEY')
    }

    stages {

        stage('Build') {
            steps {
                sh '''
                cd ai-projects/multi-agent-openai-cicd

                mvn clean install -U > build.log 2>&1 || true

                echo "===== BUILD LOG ====="
                cat build.log
                '''
            }
        }

        stage('Project Agent') {
            steps {
                sh '''
                cd ai-projects/multi-agent-openai-cicd
                export PYTHONPATH=$(pwd)

                echo "🤖 Project Agent..."
                python3 agents/project_agent.py || true
                '''
            }
        }

        stage('Security Agent') {
            steps {
                sh '''
                cd ai-projects/multi-agent-openai-cicd
                export PYTHONPATH=$(pwd)

                echo "🔐 Security Agent..."
                python3 agents/security_agent.py || true
                '''
            }
        }

	stage('Combine Reports') {
    steps {
        sh '''
        cd ai-projects/multi-agent-openai-cicd

        mkdir -p reports

        echo "📊 Creating combined report..."

        touch reports/combined.txt

        echo "===== BUILD LOG =====" > reports/combined.txt

        if [ -f build.log ]; then
            cat build.log >> reports/combined.txt
        fi

        echo "\n===== PROJECT REPORT =====" >> reports/combined.txt

        if [ -f reports/project.json ]; then
            cat reports/project.json >> reports/combined.txt
        fi

        echo "\n===== SECURITY REPORT =====" >> reports/combined.txt

        if [ -f reports/security.json ]; then
            cat reports/security.json >> reports/combined.txt
        fi

        echo "✅ combined.txt created"

        ls -R reports
        '''
    }
}

        stage('AI Decision') {
            steps {
                sh '''
                cd ai-projects/multi-agent-openai-cicd
                export PYTHONPATH=$(pwd)

                echo "🧠 AI Decision..."
                python3 agents/decision_agent.py || true
                '''
            }
        }



       stage('Commit AI Changes') {

    when {
        expression {
            return fileExists('ai-projects/multi-agent-openai-cicd/build_failed')
        }
    }

    steps {

        withCredentials([usernamePassword(
            credentialsId: '77574aa6-ebb8-4641-9540-da90dbcb1576',
            usernameVariable: 'GIT_USER',
            passwordVariable: 'GIT_PASS'
        )]) {

            sh '''
            cd ai-projects/multi-agent-openai-cicd

            git config user.email "jenkins@ai.com"
            git config user.name "Jenkins AI Bot"

            git add .

            if git diff --cached --quiet
            then
                echo "⚠️ No changes detected"
            else
                git commit -m "[ai] auto-fix by multi-agent system"

                git remote set-url origin https://$GIT_USER:$GIT_PASS@github.com/Rohitcs09/MLOPS.git

                git push origin main

                echo "✅ AI changes pushed to GitHub"
            fi
            '''
        }
    }
}



        stage('Rebuild') {
            when {
                expression {
                    return fileExists('ai-projects/multi-agent-openai-cicd/build_failed')
                }
            }
            steps {
                sh '''
                cd ai-projects/multi-agent-openai-cicd
                mvn clean install -U
                '''
            }
        }

	stage('Update Final Reports') {
    steps {

        sh '''
        cd ai-projects/multi-agent-openai-cicd

        mkdir -p reports

        echo "BUILD SUCCESS" > reports/final_status.txt

        echo "===== FINAL BUILD LOG =====" > reports/final_report.txt

        cat build.log >> reports/final_report.txt

        echo "✅ Reports Updated"
        '''
    }
}
    }
}





