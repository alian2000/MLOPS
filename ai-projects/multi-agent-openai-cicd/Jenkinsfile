pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    environment {
        OPENAI_API_KEY = credentials('OPENAI_API_KEY')
    }

    stages {

        stage('Build') {
            steps {
                sh '''
                cd ai-projects/multi-agent-openai-cicd

                mvn clean install -U > build.log 2>&1 || true

                echo "===== BUILD LOG ====="
                cat build.log
                '''
            }
        }

        stage('Project Agent') {
            steps {
                sh '''
                cd ai-projects/multi-agent-openai-cicd
                export PYTHONPATH=$(pwd)

                echo "🤖 Project Agent..."
                python3 agents/project_agent.py || true
                '''
            }
        }

        stage('Security Agent') {
            steps {
                sh '''
                cd ai-projects/multi-agent-openai-cicd
                export PYTHONPATH=$(pwd)

                echo "🔐 Security Agent..."
                python3 agents/security_agent.py || true
                '''
            }
        }

        stage('AI Decision') {
            steps {
                sh '''
                cd ai-projects/multi-agent-openai-cicd
                export PYTHONPATH=$(pwd)

                echo "🧠 AI Decision..."
                python3 agents/decision_agent.py || true
                '''
            }
        }

        stage('AI Fix') {
            when {
                expression {
                    return fileExists('ai-projects/multi-agent-openai-cicd/build_failed')
                }
            }
            steps {
                sh '''
                cd ai-projects/multi-agent-openai-cicd
                export PYTHONPATH=$(pwd)

                echo "🔧 Fix Agent..."
                python3 agents/fix_agent.py || true
                '''
            }
        }

        stage('Rebuild') {
            when {
                expression {
                    return fileExists('ai-projects/multi-agent-openai-cicd/build_failed')
                }
            }
            steps {
                sh '''
                cd ai-projects/multi-agent-openai-cicd
                mvn clean install -U
                '''
            }
        }
    }
}
