pipeline {

    agent any

    tools {
        maven 'Maven3'
    }

    environment {
        PROJECT_PATH = "ai-projects/multi-agent-openai-cicd"
    }

    stages {

        stage('Clone Check') {
            steps {
                echo "Repository cloned successfully"
            }
        }

        stage('Build') {

            steps {

                script {

                    sh '''
                    cd ${PROJECT_PATH}

                    mkdir -p reports

                    mvn clean install -U > build.log 2>&1

                    echo $? > build_status.txt
                    '''

                    def status = readFile(
                        "${PROJECT_PATH}/build_status.txt"
                    ).trim()

                    if (status != '0') {

                        echo "❌ Build Failed"

                        writeFile(
                            file: "${PROJECT_PATH}/build_failed",
                            text: "failed"
                        )

                    } else {

                        echo "✅ Build Passed"

                    }

                }

            }

        }

        stage('Project Agent') {
            steps {

                sh '''
                cd ${PROJECT_PATH}

                export PYTHONPATH=$(pwd)

                python3 agents/project_agent.py
                '''

            }
        }

        stage('Security Agent') {
            steps {

                sh '''
                cd ${PROJECT_PATH}

                export PYTHONPATH=$(pwd)

                python3 agents/security_agent.py
                '''

            }
        }

        stage('Decision Agent') {
            steps {

                sh '''
                cd ${PROJECT_PATH}

                export PYTHONPATH=$(pwd)

                python3 agents/decision_agent.py
                '''

            }
        }

        stage('Fix Agent') {

            when {
                expression {
                    return fileExists("${PROJECT_PATH}/build_failed")
                }
            }

            steps {

                sh '''
                cd ${PROJECT_PATH}

                export PYTHONPATH=$(pwd)

                python3 agents/fix_agent.py
                '''

            }

        }

        stage('Rebuild') {

            when {
                expression {
                    return fileExists("${PROJECT_PATH}/build_failed")
                }
            }

            steps {

                sh '''
                cd ${PROJECT_PATH}

                mvn clean install -U
                '''

            }

        }

    }

    post {

        always {

            archiveArtifacts artifacts: '**/reports/*.json', fingerprint: true

        }

    }

}
