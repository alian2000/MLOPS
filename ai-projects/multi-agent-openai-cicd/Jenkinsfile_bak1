pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    environment {
        OPENAI_API_KEY = credentials('OPENAI_API_KEY')
    }

    stages {

            stage('Clone Code') {
            steps {
                git branch: 'main',
                    credentialsId: '77574aa6-ebb8-4641-9540-da90dbcb1576',
                    url: 'https://github.com/Rohitcs09/MLOPS.git'
            }
        }


        
           stage('Skip AI Loop') {
            steps {
                script {
                    def msg = sh(script: "git log -1 --pretty=%B", returnStdout: true).trim()
                    echo "Last commit message: ${msg}"

                    if (msg.contains("[ai]")) {
                        echo "AI commit detected → stopping loop"
                        currentBuild.result = 'SUCCESS'
                        return
                    }
                }
            }
        }
        




      
        stage('Build') {
    steps {
        script {
            dir("ai-projects/multi-agent-openai-cicd") {

                def status = sh(script: 'mvn clean install -U > build.log 2>&1', returnStatus: true)

                if (status != 0) {
                    echo "❌ Build Failed"
                    currentBuild.result = 'FAILURE'
                } else {
                    echo "✅ Build Success"
		     currentBuild.result = 'SUCCESS'
                }
            }
        }
    }
} 


        stage('Project Agent') {
            steps {
                sh 'python3 ai-projects/multi-agent-openai-cicd/agents/project_agent.py'
            }
        }

        


	stage('Security Agent') {
    steps {
        dir("ai-projects/multi-agent-openai-cicd") {
            sh '''
            echo "🔐 Running Security Agent..."
            python3 agents/security_agent.py
            '''
        }
    }
}


        stage('Combine Report') {
    steps {
        dir("ai-projects/multi-agent-openai-cicd") {
            sh '''
            echo "📁 Current dir:"
            pwd

            mkdir -p reports

            echo "📊 Combining reports..."

            cat reports/project.json reports/security.json > reports/combined.txt

            echo "✅ Combined report created"
            '''
        }
    }
}


        stage('Decision Agent') {
            steps {
                sh 'python3 ai-projects/multi-agent-openai-cicd/agents/decision_agent.py' || true
            }
        }

        stage('Fix Agent') {
            when {
                expression { fileExists('build_failed') }
            }
            steps {
                sh 'python3 ai-projects/multi-agent-openai-cicd/agents/fix_agent.py'
            }
        }




        // -------------------------------
// 🤖 AI FIX STAGE
// -------------------------------


stage('AI Fix') {
    when {
        expression {
            return currentBuild.result == 'FAILURE'
        }
    }

    steps {
        script {

            withCredentials([
                usernamePassword(
                    credentialsId: '77574aa6-ebb8-4641-9540-da90dbcb1576',
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_PASS'
                ),
                string(
                    credentialsId: 'OPENAI_API_KEY',
                    variable: 'OPENAI_API_KEY'
                )
            ]) {

                dir("ai-projects/multi-agent-openai-cicd") {

                    sh '''
                    echo "📂 WORKSPACE:"
                    pwd

                    echo "📦 Running Fix Agent..."
                    python3 agents/fix_agent.py

                    echo "📄 Checking files"
                    cat pom.xml || true
                    cat src/main/java/WebApp.java || true

                    git config user.email "jenkins@ai.com"
                    git config user.name "Jenkins AI Bot"

                    git add -A

                    if git diff --cached --quiet; then
                        echo "⚠️ No changes"
                        exit 0
                    fi

                    git commit -m "[AI] auto fix applied"

                    git remote set-url origin https://$GIT_USER:$GIT_PASS@github.com/Rohitcs09/MLOPS.git

                    git push origin main --force
                    '''
                }
            }
        }
    }
}





               // -------------------------------
// 🔁 REBUILD AFTER FIX
// -------------------------------


// -------------------------------
// 🔁 REBUILD AFTER AI FIX
// -------------------------------
stage('Rebuild After Fix') {

    when {
        expression {
            return currentBuild.result == 'FAILURE'
        }
    }

    steps {
        script {

            echo "🔁 Running Rebuild After AI Fix..."

            dir("ai-projects/multi-agent-openai-cicd") {

                def status = sh(script: '''
                echo "📂 Working Directory:"
                pwd

                echo "🔁 Starting Maven Rebuild..."

                mvn clean install -U > build_after_fix.log 2>&1
                ''', returnStatus: true)

                if (status != 0) {

                    echo "❌ Rebuild still failing after AI fix"
                    currentBuild.result = 'FAILURE'

                    error("❌ Pipeline failed after AI fix")

                } else {

                    echo "✅ REBUILD SUCCESSFUL AFTER AI FIX"
                    currentBuild.result = 'SUCCESS'

                    sh '''
                    echo "📄 Build Log Preview:"
                    tail -n 20 build_after_fix.log || true
                    '''
                }
            }
        }
    }
}


    }
}
