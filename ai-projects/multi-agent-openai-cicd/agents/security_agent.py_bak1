import json

print("🔐 Security Agent analyzing pom.xml...")

with open("ai-projects/multi-agent-openai-cicd/pom.xml", "r") as f:
    pom = f.read()

report = {
    "status": "SUCCESS",
    "vulnerabilities": []
}

# -------------------------------
# LOG4J SECURITY CHECK
# -------------------------------

if "1.1.1" in pom or "1.1.0" in pom:

    report["status"] = "FAILED"

    vulnerability = {
        "library": "log4j",
        "severity": "CRITICAL",
        "cve": "CVE-2021-44228",
        "description": "Log4j versions <= 2.14.1 are vulnerable to Remote Code Execution (RCE) via JNDI lookup vulnerability.",
        
        "impact": [
            "Remote code execution on server",
            "Full system compromise possible",
            "Data exfiltration risk",
            "Can be exploited via simple log injection"
        ],

        "fix_recommendation": "Upgrade log4j to version 2.17.1 or latest secure version",
        
        "detected_version": "1.1.x (suspected unsafe dependency mapping)"
    }

    report["vulnerabilities"].append(vulnerability)

# -------------------------------
# OUTPUT REPORT
# -------------------------------

output_path = "ai-projects/multi-agent-openai-cicd/reports/security.json"

with open(output_path, "w") as f:
    json.dump(report, f, indent=4)

print("\n🔐 SECURITY REPORT GENERATED:")
print(json.dumps(report, indent=4))
