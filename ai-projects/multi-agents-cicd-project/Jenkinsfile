pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    stages {

        stage('Clone Code') {
            steps {
                git branch: 'main',
                    credentialsId: '77574aa6-ebb8-4641-9540-da90dbcb1576',
                    url: 'https://github.com/Rohitcs09/MLOPS.git'
            }
        }

        stage('Skip AI Loop') {
            steps {
                script {
                    def msg = sh(script: "git log -1 --pretty=%B", returnStdout: true).trim()
                    echo "Last commit message: ${msg}"

                    if (msg.contains("[ai]")) {
                        echo "AI commit detected → stopping loop"
                        currentBuild.result = 'SUCCESS'
                        return
                    }
                }
            }
        }

        // 🔥 BUILD (NO WRONG PATH)


                stage('Build with Maven') {
    steps {
        script {
            sh '''
            echo "📂 Current Workspace:"
            pwd
            ls -l

            echo "📂 Navigating to Project..."
            cd ai-projects/multi-agents-cicd-project

            ls -l

            mkdir -p reports

            mvn clean install -U | tee build.log
            '''

            def log = readFile 'ai-projects/multi-agents-cicd-project/build.log'

            echo "===== BUILD LOG START ====="
            echo log
            echo "===== BUILD LOG END ====="

            if (log.contains("BUILD FAILURE")) {
                writeFile file: 'ai-projects/multi-agents-cicd-project/build_failed', text: 'failed'
                error("❌ Build Failed")
            } else {
                echo "✅ Build Passed"
            }
        }
    }
}






        // 🤖 PROJECT AGENT
        stage('Project Agent') {
            steps {
                sh 'python3 agents/project_agent.py || python agents/project_agent.py'
            }
        }

        // 🔐 SECURITY AGENT
        stage('Security Agent') {
            steps {
                sh 'python3 agents/security_agent.py || python agents/security_agent.py'
            }
        }

        // 🧠 AI DECISION
        stage('AI Decision Agent') {
            steps {
                script {
                    def status = sh(script: '''
                        python3 ai_agent.py || python ai_agent.py
                    ''', returnStatus: true)

                    if (status != 0) {
                        echo "🚨 AI rejected build"
                        writeFile file: 'build_failed', text: 'failed'
                    } else {
                        echo "✅ AI approved build"
                    }
                }
            }
        }

        // 🤖 AUTO FIX
        stage('AI Fix') {
            when {
                expression {
                    return fileExists('build_failed')
                }
            }
            steps {
                script {
                    echo "🤖 Running AI Fix..."

                    withCredentials([usernamePassword(
                        credentialsId: '77574aa6-ebb8-4641-9540-da90dbcb1576',
                        usernameVariable: 'GIT_USER',
                        passwordVariable: 'GIT_PASS'
                    )]) {

                        sh '''
                        python3 ai_agent.py || python ai_agent.py

                        git config user.email "jenkins@ai.com"
                        git config user.name "Jenkins AI Bot"

                        git add .

                        if git diff --cached --quiet; then
                          echo "No changes"
                        else
                          git commit -m "[ai] auto-fix issue"
                          git remote set-url origin https://$GIT_USER:$GIT_PASS@github.com/Rohitcs09/MLOPS.git
                          git push origin main
                        fi
                        '''
                    }
                }
            }
        }

        // 🔁 REBUILD
        stage('Rebuild After Fix') {
            when {
                expression {
                    return fileExists('build_failed')
                }
            }
            steps {
                script {
                    def status = sh(script: 'mvn clean install -U', returnStatus: true)

                    if (status != 0) {
                        error("❌ Build still failing after AI fix")
                    } else {
                        echo "✅ Build Fixed Successfully"
                    }
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'reports/*.json', allowEmptyArchive: true
        }
        success {
            echo "🎉 Multi-Agent CI/CD Success"
        }
        failure {
            echo "❌ Pipeline Failed"
        }
    }
}
