pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    environment {
        PROJECT_PATH = "ai-projects/multi-agents-cicd-project"
        POM_PATH = "ai-projects/multi-agents-cicd-project/pom.xml"
    }

    stages {

        stage('Clone Code') {
            steps {
                git branch: 'main',
                    credentialsId: '77574aa6-ebb8-4641-9540-da90dbcb1576',
                    url: 'https://github.com/Rohitcs09/MLOPS.git'
            }
        }

        stage('Build with Maven') {
            steps {
                script {

                    sh """
                    mkdir -p ${PROJECT_PATH}/reports

                    echo "🚀 Running Maven Build..."

                    mvn -f ${POM_PATH} clean install -U | tee ${PROJECT_PATH}/build.log
                    """

                    def log = readFile "${PROJECT_PATH}/build.log"

                    echo "===== BUILD LOG START ====="
                    echo log
                    echo "===== BUILD LOG END ====="

                    // reset flag
                    sh "rm -f ${PROJECT_PATH}/build_failed || true"

                    if (log.contains("BUILD FAILURE")) {
                        writeFile file: "${PROJECT_PATH}/build_failed", text: 'failed'
                        echo "❌ Build Failed → flag created"
                    } else {
                        echo "✅ Build Passed"
                    }
                }
            }
        }

        stage('Project Agent') {
            steps {
                sh """
                echo "🤖 Project Agent..."

                if command -v python3 >/dev/null 2>&1; then
                    python3 ${PROJECT_PATH}/agents/project_agent.py
                else
                    python ${PROJECT_PATH}/agents/project_agent.py
                fi
                """
            }
        }

        stage('Security Agent') {
            steps {
                sh """
                echo "🔐 Security Agent..."

                if command -v python3 >/dev/null 2>&1; then
                    python3 ${PROJECT_PATH}/agents/security_agent.py
                else
                    python ${PROJECT_PATH}/agents/security_agent.py
                fi
                """
            }
        }

        stage('AI Decision Agent') {
            steps {
                script {
                    def status = sh(script: """
                    echo "🧠 AI Decision..."

                    if command -v python3 >/dev/null 2>&1; then
                        python3 ${PROJECT_PATH}/ai_agent.py
                    else
                        python ${PROJECT_PATH}/ai_agent.py
                    fi
                    """, returnStatus: true)

                    if (status != 0) {
                        echo "🚨 AI rejected build"
                        writeFile file: "${PROJECT_PATH}/build_failed", text: 'failed'
                    } else {
                        echo "✅ AI approved build"
                    }
                }
            }
        }

        stage('AI Fix') {
            when {
                expression {
                    return fileExists("${PROJECT_PATH}/build_failed")
                }
            }
            steps {
                script {
                    echo "🤖 Running AI Fix..."

                    withCredentials([usernamePassword(
                        credentialsId: '77574aa6-ebb8-4641-9540-da90dbcb1576',
                        usernameVariable: 'GIT_USER',
                        passwordVariable: 'GIT_PASS'
                    )]) {

                        sh """
                        if command -v python3 >/dev/null 2>&1; then
                            python3 ${PROJECT_PATH}/ai_agent.py
                        else
                            python ${PROJECT_PATH}/ai_agent.py
                        fi

                        git config user.email "jenkins@ai.com"
                        git config user.name "Jenkins AI Bot"

                        git add .

                        if git diff --cached --quiet; then
                          echo "No changes"
                        else
                          git commit -m "[ai] auto-fix issue"
                          git remote set-url origin https://$GIT_USER:$GIT_PASS@github.com/Rohitcs09/MLOPS.git
                          git push origin main
                        fi
                        """
                    }
                }
            }
        }

        stage('Rebuild After Fix') {
            when {
                expression {
                    return fileExists("${PROJECT_PATH}/build_failed")
                }
            }
            steps {
                script {
                    def status = sh(script: """
                        mvn -f ${POM_PATH} clean install -U
                    """, returnStatus: true)

                    if (status != 0) {
                        error("❌ Build still failing after AI fix")
                    } else {
                        echo "✅ Build Fixed Successfully"
                    }
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: "${PROJECT_PATH}/reports/*.json", allowEmptyArchive: true
        }
    }
}
