pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    environment {
        PROJECT_PATH = "ai-projects/hybrid-self-healing-agent"
    }

    stages {

        stage('Clone Code') {
            steps {
                git branch: 'main',
                    credentialsId: '77574aa6-ebb8-4641-9540-da90dbcb1576',
                    url: 'https://github.com/Rohitcs09/MLOPS.git'
            }
        }

        stage('Skip AI Loop') {
            steps {
                script {
                    def msg = sh(script: "git log -1 --pretty=%B", returnStdout: true).trim()
                    echo "Last commit message: ${msg}"

                    if (msg.contains("[ai]")) {
                        echo "AI commit detected → stopping loop"
                        currentBuild.result = 'SUCCESS'
                        return
                    }
                }
            }
        }

        // 🔥 BUILD + LOG CAPTURE (same as yours)
        stage('Build with Maven') {
            steps {
                script {
                    def status = sh(script: """
                        cd ${PROJECT_PATH}
                        mkdir -p reports
                        mvn clean install -U > build.log 2>&1
                    """, returnStatus: true)

                    def log = readFile "${PROJECT_PATH}/build.log"
                    echo "===== BUILD LOG START ====="
                    echo log
                    echo "===== BUILD LOG END ====="

                    if (status != 0) {
                        echo "❌ Build Failed"
                        writeFile file: "${PROJECT_PATH}/build_failed", text: 'failed'
                    } else {
                        echo "✅ Build Passed"
                    }
                }
            }
        }

        // 🤖 PROJECT AGENT
        stage('Project Agent') {
            steps {
                script {
                    sh """
                    cd ${PROJECT_PATH}
                    python3 agents/project_agent.py || python agents/project_agent.py
                    """
                }
            }
        }

        // 🔐 SECURITY AGENT
        stage('Security Agent') {
            steps {
                script {
                    sh """
                    cd ${PROJECT_PATH}
                    python3 agents/security_agent.py || python agents/security_agent.py
                    """
                }
            }
        }

        // 🧠 AI DECISION AGENT
        stage('AI Decision Agent') {
            steps {
                script {
                    def status = sh(script: """
                        cd ${PROJECT_PATH}
                        python3 ai_agent.py || python ai_agent.py
                    """, returnStatus: true)

                    if (status != 0) {
                        echo "🚨 AI rejected build"
                        writeFile file: "${PROJECT_PATH}/build_failed", text: 'failed'
                    } else {
                        echo "✅ AI approved build"
                    }
                }
            }
        }

        // 🤖 AUTO-FIX (same but improved)
        stage('AI Fix') {
            when {
                expression {
                    return fileExists("${PROJECT_PATH}/build_failed")
                }
            }
            steps {
                script {
                    echo "🤖 Running Hybrid AI Fix..."

                    withCredentials([usernamePassword(
                        credentialsId: '77574aa6-ebb8-4641-9540-da90dbcb1576',
                        usernameVariable: 'GIT_USER',
                        passwordVariable: 'GIT_PASS'
                    )]) {

                        sh """
                        cd ${PROJECT_PATH}

                        echo "📂 Project Structure:"
                        ls -R

                        python3 ai_agent.py || python ai_agent.py

                        git config user.email "jenkins@ai.com"
                        git config user.name "Jenkins AI Bot"

                        git add .

                        if git diff --cached --quiet; then
                          echo "No changes"
                        else
                          git commit -m "[ai] auto-fix code + dependency issue"
                          git remote set-url origin https://$GIT_USER:$GIT_PASS@github.com/Rohitcs09/MLOPS.git
                          git push origin main
                        fi
                        """
                    }
                }
            }
        }

        // 🔁 REBUILD AFTER FIX
        stage('Rebuild After Fix') {
            when {
                expression {
                    return fileExists("${PROJECT_PATH}/build_failed")
                }
            }
            steps {
                script {
                    def status = sh(script: """
                        cd ${PROJECT_PATH}
                        mvn clean install -U
                    """, returnStatus: true)

                    if (status != 0) {
                        error("❌ Build still failing after AI fix")
                    } else {
                        echo "✅ Build Fixed Successfully"
                    }
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: "${PROJECT_PATH}/reports/*.json", allowEmptyArchive: true
        }
        success {
            echo "🎉 Multi-Agent CI/CD Success"
        }
        failure {
            echo "❌ Pipeline Failed (Even After AI Fix)"
        }
    }
}
