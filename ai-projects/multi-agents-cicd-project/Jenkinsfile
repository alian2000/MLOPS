pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    environment {
        PROJECT_PATH = "ai-projects/multi-agents-cicd-project"
        POM_PATH = "ai-projects/multi-agents-cicd-project/pom.xml"
    }

    stages {

        stage('Clone Code') {
            steps {
                git branch: 'main',
                    credentialsId: '77574aa6-ebb8-4641-9540-da90dbcb1576',
                    url: 'https://github.com/Rohitcs09/MLOPS.git'
            }
        }

        stage('Build') {
            steps {
                script {
                    sh """
                    mkdir -p ${PROJECT_PATH}/reports

                    mvn -f ${POM_PATH} clean install -U | tee ${PROJECT_PATH}/build.log
                    """

                    def log = readFile "${PROJECT_PATH}/build.log"

                    sh "rm -f ${PROJECT_PATH}/build_failed || true"

                    if (log.contains("BUILD FAILURE")) {
                        writeFile file: "${PROJECT_PATH}/build_failed", text: 'failed'
                    }
                }
            }
        }


       stage('Project Agent') {
    steps {
        sh '''
        echo "📂 Checking path..."
        pwd
        ls -R

        echo "🤖 Running Project Agent..."

        if [ -f ai-projects/multi-agents-cicd-project/agents/project_agent.py ]; then
            python3 ai-projects/multi-agents-cicd-project/agents/project_agent.py || true
        else
            echo "❌ project_agent.py NOT FOUND"
        fi
        '''
    }
}


        stage('Security Agent') {
            steps {
                script {
                    sh "python3 ${PROJECT_PATH}/agents/security_agent.py || true"
                }
            }
        }

        stage('AI Decision') {
            steps {
                script {
                    def status = sh(script: "python3 ${PROJECT_PATH}/ai_agent.py", returnStatus: true)

                    if (status != 0) {
                        writeFile file: "${PROJECT_PATH}/build_failed", text: 'failed'
                    }
                }
            }
        }

        stage('AI Fix') {
            when {
                expression {
                    return fileExists("${PROJECT_PATH}/build_failed")
                }
            }
            steps {
                script {
                    withCredentials([usernamePassword(
                        credentialsId: '77574aa6-ebb8-4641-9540-da90dbcb1576',
                        usernameVariable: 'GIT_USER',
                        passwordVariable: 'GIT_PASS'
                    )]) {

                        sh """
                        python3 ${PROJECT_PATH}/fix_agent.py

                        git config user.email "jenkins@ai.com"
                        git config user.name "Jenkins AI Bot"

                        git add .
                        git commit -m "[ai] auto fix" || true
                        """

                        withEnv(["GIT_URL=https://${GIT_USER}:${GIT_PASS}@github.com/Rohitcs09/MLOPS.git"]) {
                            sh '''
                            git remote set-url origin $GIT_URL
                            git push origin main
                            '''
                        }
                    }
                }
            }
        }

        stage('Rebuild') {
            when {
                expression {
                    return fileExists("${PROJECT_PATH}/build_failed")
                }
            }
            steps {
                sh "mvn -f ${POM_PATH} clean install -U"
            }
        }
    }
}
